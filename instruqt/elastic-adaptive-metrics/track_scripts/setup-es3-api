Type=simple
Environment=PYTHONPATH=/opt/noisy-metrics-shipper/pkg
EnvironmentFile=/etc/noisy-metrics.env
WorkingDirectory=/opt/noisy-metrics-shipper
ExecStart=/usr/bin/python3 /opt/noisy-metrics-shipper/noisy_otlp_metrics.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=noisy-metrics-otlp

[Install]
WantedBy=multi-user.target
UNIT

    systemctl daemon-reload
    systemctl enable noisy-metrics-otlp
    if systemctl start noisy-metrics-otlp; then
      echo "✅ noisy-metrics-otlp service started (mOTLP: ${MOTLP_URL_EFFECTIVE})"
    else
      echo "WARN: noisy-metrics-otlp failed to start — check journalctl -u noisy-metrics-otlp"
    fi
  else
    echo "INFO: Noisy OTLP shipper skipped. Set MOTLP_URL on the es3-api host (Instruqt Sandbox → VM env),"
    echo "      or ensure /tmp/project_results.json includes an ingest/otlp endpoint under endpoints.*"
    echo "      and ELASTICSEARCH_API_KEY is set. See: instruqt/.../track_scripts/noisy_otlp_metrics.py"
  fi
else
  echo "INFO: Noisy OTLP shipper disabled (DISABLE_NOISY_METRICS_SHIPPER=1)."
fi

# Convenience aliases
cat >> /root/.bashrc <<'BASH'

# Elastic Demo aliases
alias demo-logs="journalctl -u elastic-demo -f --no-pager"
alias demo-status="curl -sf http://localhost:8090/api/status | python3 -m json.tool"
alias demo-deployments="curl -sf http://localhost:8090/api/deployments | python3 -m json.tool"
alias demo-chaos="curl -sf http://localhost:8090/api/chaos/status | python3 -m json.tool"
alias demo-restart="systemctl restart elastic-demo && sleep 3 && curl -sf http://localhost:8090/health"
alias noisy-metrics-logs="journalctl -u noisy-metrics-otlp -f --no-pager"
alias noisy-metrics-status="systemctl is-active noisy-metrics-otlp 2>/dev/null || echo inactive"
BASH


echo "Track setup complete."
