# Instruqt may execute this script from a staged path (e.g. under /tmp) without copying
# bundled assets. Resolve the directory that contains track_scripts/dashboards and workflows/.
_resolve_track_scripts_dir() {
  local script_home="$1"
  local dash_rel="dashboards/instruqt-metric-governance-dashboard.json"
  if [[ -f "${script_home}/${dash_rel}" ]]; then
    printf '%s\n' "${script_home}"
    return 0
  fi
  local d="$script_home"
  local _
  for _ in $(seq 1 24); do
    if [[ -f "${d}/track_scripts/${dash_rel}" ]]; then
      (cd "${d}/track_scripts" && pwd)
      return 0
    fi
    [[ "${d}" == "/" ]] && break
    d="$(dirname "${d}")"
  done
  local hit=""
  local root
  for root in /tmp /root /home /opt /var/lib /usr/local /instruqt "${HOME:-}"; do
    [[ -d "${root}" ]] || continue
    hit="$(find "${root}" -maxdepth 16 -path '*/track_scripts/dashboards/instruqt-metric-governance-dashboard.json' 2>/dev/null | head -n1)"
    [[ -n "${hit}" ]] || continue
    (cd "$(dirname "$(dirname "${hit}")")" && pwd)
    return 0
  done
  printf '%s\n' "${script_home}"
  return 1
}

