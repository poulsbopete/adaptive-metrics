try:
    d=json.load(sys.stdin)
    print(len(d) if isinstance(d,list) else len(d.get('data',d.get('results',d.get('items',[])))))
except: print(0)" 2>/dev/null || echo 0)
  if [[ "${count:-0}" -lt 1 ]]; then
    raw=$(curl -s --max-time 30 -X POST -H "Authorization: ApiKey ${DEMO_API_KEY}" -H "kbn-xsrf: true" \
      -H "Content-Type: application/json" -d '{"page":1,"size":100}' \
