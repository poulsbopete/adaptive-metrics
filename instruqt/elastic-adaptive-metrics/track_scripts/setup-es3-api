  listen 8080 default_server;
  server_name kibana;
  location /nginx_status {
    stub_status on;
    allow 127.0.0.1;
    deny all;
  }
  location /loading {
    alias /usr/share/nginx/html/loading;
    index index.html;
    try_files $uri $uri/ /loading/index.html;
    add_header X-Frame-Options "SAMEORIGIN";
  }
  location /chatbot {
    alias /usr/share/nginx/html/chatbot;
    index index.html;
    try_files $uri $uri/ /chatbot/index.html;
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Content-Type, Authorization" always;
    # Remove X-Frame-Options to allow iframe embedding
    # (or we could set it to empty, but removing is cleaner)
  }
  location /metric-bot {
    proxy_pass https://metric-bot.vercel.app/;
    proxy_set_header Host metric-bot.vercel.app;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_ssl_verify off;
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Content-Type, Authorization" always;
    # Remove X-Frame-Options to allow embedding
    proxy_hide_header X-Frame-Options;
    
    # Handle CORS preflight
    if ($request_method = OPTIONS) {
      add_header Access-Control-Allow-Origin "*";
      add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
      add_header Access-Control-Allow-Headers "Content-Type, Authorization";
      add_header Content-Length 0;
      add_header Content-Type text/plain;
      return 204;
    }
  }
  location /mcp-proxy {
    proxy_pass https://ai-assistants-ffcafb.kb.us-east-1.aws.elastic.cloud/api/agent_builder/mcp;
    proxy_set_header Authorization "ApiKey SFBCQzlac0JBUENqajRQVTJ5VTM6WjRmYnhvWF9hdnM3aXNMZEpFUWlmZw==";
    proxy_set_header Content-Type "application/json";
    proxy_set_header Host ai-assistants-ffcafb.kb.us-east-1.aws.elastic.cloud;
