# POST dashboards/instruqt-metric-governance-dashboard.json (bundled under track_scripts/dashboards/).
_push_metric_governance_dashboard() {
  local json_file="${TRACK_SCRIPT_DIR}/dashboards/instruqt-metric-governance-dashboard.json"
  if [[ ! -f "$json_file" ]]; then
    echo "WARN: Adaptive Metrics dashboard JSON missing at $json_file — skipping POST."
    return 2
  fi
  echo "Creating Adaptive Metrics / metric governance dashboard in Kibana (POST /api/dashboards)..."
  export GOVERNANCE_DASHBOARD_JSON="$json_file"
  KIBANA_URL="$DEMO_KIBANA_URL" ES_API_KEY="$DEMO_API_KEY" python3 <<'PY'
import json, os, pathlib, sys, urllib.error, urllib.request

API_VERSION = os.environ.get("KIBANA_DASHBOARDS_API_VERSION", "2023-10-31")
base = (os.environ.get("KIBANA_URL") or "").rstrip("/")
key = os.environ.get("ES_API_KEY") or ""
path = pathlib.Path(os.environ.get("GOVERNANCE_DASHBOARD_JSON", ""))
if not base or not key or not path.is_file():
    print("WARN: skip governance dashboard — missing Kibana URL, API key, or JSON path")
    sys.exit(2)

spec = json.loads(path.read_text(encoding="utf-8"))
spec.pop("time_from", None)
spec.pop("time_to", None)
payload = json.dumps(spec).encode("utf-8")
req = urllib.request.Request(
    f"{base}/api/dashboards",
    data=payload,
    method="POST",
    headers={
        "Authorization": f"ApiKey {key}",
        "kbn-xsrf": "true",
        "Content-Type": "application/json",
        "Elastic-Api-Version": API_VERSION,
        "Accept-Encoding": "identity",
    },
)
try:
    with urllib.request.urlopen(req, timeout=120) as resp:
        body = resp.read().decode("utf-8", errors="replace")
        out = json.loads(body)
        did = out.get("id", "?")
        print(f"✅ Adaptive Metrics dashboard created — HTTP {resp.status} — id={did}")
except urllib.error.HTTPError as e:
    err = e.read().decode("utf-8", errors="replace")[:8000]
    code = e.code
    err_lower = err.lower()
    # Duplicate / conflict — dashboard likely already installed (retry run or race).
    if code == 409 or "duplicate" in err_lower or "already exists" in err_lower or "conflict" in err_lower:
        print(f"INFO: Dashboard POST returned HTTP {code} — treating as already present: {err[:400]}")
        sys.exit(0)
    print(f"WARN: Governance dashboard POST failed HTTP {code}: {err[:2500]}")
    sys.exit(1)
except urllib.error.URLError as e:
    print(f"WARN: Governance dashboard request failed (network): {e}")
    sys.exit(1)
sys.exit(0)
PY
}

# POST workflows/kibana/metric-governance-retail-banking-starter.yaml (bundled under track_scripts/workflows/).
_push_metric_governance_workflow() {
  local yaml_file="${TRACK_SCRIPT_DIR}/workflows/metric-governance-retail-banking-starter.yaml"
  local wf_id="${METRIC_GOVERNANCE_WORKFLOW_ID:-adaptive-metrics-metric-governance-starter}"
  if [[ ! -f "$yaml_file" ]]; then
    echo "WARN: Metric governance workflow YAML missing at $yaml_file — skipping POST."
    return 0
  fi
  echo "Installing Adaptive Metrics governance workflow (POST /api/workflows/workflow id=${wf_id})..."
  export METRIC_GOV_YAML_PATH="$yaml_file"
  export METRIC_GOV_WORKFLOW_ID="$wf_id"
  KIBANA_URL="$DEMO_KIBANA_URL" ES_API_KEY="$DEMO_API_KEY" python3 <<'PY'
import gzip, json, os, pathlib, sys, urllib.error, urllib.request

def decode_body(raw: bytes) -> str:
    if raw[:2] == b"\x1f\x8b":
        raw = gzip.decompress(raw)
    return raw.decode("utf-8", errors="replace")

def request(method: str, url: str, data: bytes | None, headers: dict) -> tuple[int, str]:
    r = urllib.request.Request(url, data=data, method=method, headers=headers)
    try:
        with urllib.request.urlopen(r, timeout=120) as resp:
            return resp.status, decode_body(resp.read())
    except urllib.error.HTTPError as e:
        return e.code, decode_body(e.read())
    except urllib.error.URLError as e:
        return -1, str(e)

kb = (os.environ.get("KIBANA_URL") or "").rstrip("/")
key = os.environ.get("ES_API_KEY") or ""
path = pathlib.Path(os.environ.get("METRIC_GOV_YAML_PATH", ""))
wid = os.environ.get("METRIC_GOV_WORKFLOW_ID", "adaptive-metrics-metric-governance-starter")
if not kb or not key or not path.is_file():
    print("WARN: skip governance workflow — missing Kibana URL, API key, or YAML path")
    sys.exit(2)

yaml_text = path.read_text(encoding="utf-8")
headers = {
    "Authorization": f"ApiKey {key}",
    "kbn-xsrf": "true",
    "Content-Type": "application/json; charset=utf-8",
}
post_url = f"{kb}/api/workflows/workflow"
put_url = f"{kb}/api/workflows/workflow/{wid}"
body_post = json.dumps({"id": wid, "yaml": yaml_text}).encode("utf-8")
body_put = json.dumps({"yaml": yaml_text}).encode("utf-8")

code, text = request("POST", post_url, body_post, headers)
if code == -1:
    print(f"WARN: governance workflow POST network error: {text}")
    sys.exit(1)
if code in (200, 201):
    print(f"✅ Metric governance workflow created — HTTP {code}")
    sys.exit(0)

err_lower = text.lower()
# Validation conflict / already exists — try PUT (same as scripts/push_kibana_workflow.py).
if code in (400, 409) or "already exists" in err_lower or "duplicate" in err_lower:
    code2, text2 = request("PUT", put_url, body_put, headers)
    if code2 == -1:
        print(f"WARN: governance workflow PUT network error: {text2}")
        sys.exit(1)
    if code2 == 200:
        print(f"✅ Metric governance workflow updated — HTTP {code2}")
        sys.exit(0)
    print(f"WARN: governance workflow PUT failed HTTP {code2}: {text2[:2500]}")
    sys.exit(1)

print(f"WARN: governance workflow POST failed HTTP {code}: {text[:2500]}")
sys.exit(1)
PY
}

