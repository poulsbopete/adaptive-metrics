# ── Streams / governance lab: high-cardinality OTLP metrics via mOTLP ───────
# Ships to a dedicated dataset (data_stream.dataset=governance.noisy) so learners
# can target retention, child streams, and rollups without touching core banking series.
_discover_motlp_url() {
  local region="${REGIONS:-}" f="/tmp/project_results.json"
  [[ -f "$f" && -n "$region" ]] || return 1
  local url key
  for key in otlp ingest observability_ingest motlp telemetry apm; do
    url="$(jq -r --arg r "$region" --arg k "$key" '.[$r].endpoints[$k] // empty' "$f" 2>/dev/null || true)"
    if [[ -n "$url" && "$url" != "null" ]]; then
      printf '%s\n' "$url"
      return 0
    fi
  done
  while IFS= read -r url; do
    [[ -z "$url" || "$url" == "null" ]] && continue
    if echo "$url" | grep -qiE 'otlp|ingest|telemetry'; then
      printf '%s\n' "$url"
      return 0
    fi
  done < <(jq -r --arg r "$region" '.[$r].endpoints // {} | to_entries[] | .value | strings' "$f" 2>/dev/null || true)
  return 1
}

